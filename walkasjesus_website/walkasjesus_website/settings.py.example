# Cache backend configuration
# Local default: FileBasedCache (persists across webserver restarts).
# Production Redis: set these environment variables:
# - DJANGO_CACHE_BACKEND=django_redis.cache.RedisCache
# - DJANGO_CACHE_LOCATION=redis://127.0.0.1:6379/1 (adjust host/db)
# Also install django-redis in the production environment.
DJANGO_CACHE_BACKEND = os.getenv('DJANGO_CACHE_BACKEND', 'django.core.cache.backends.filebased.FileBasedCache')
DJANGO_CACHE_LOCATION = os.getenv('DJANGO_CACHE_LOCATION', os.path.join(BASE_DIR, '.django_cache'))

if DJANGO_CACHE_BACKEND == 'django.core.cache.backends.filebased.FileBasedCache':
    os.makedirs(DJANGO_CACHE_LOCATION, exist_ok=True)

CACHES = {
    'default': {
        'BACKEND': DJANGO_CACHE_BACKEND,
        'LOCATION': DJANGO_CACHE_LOCATION,
    }
}

